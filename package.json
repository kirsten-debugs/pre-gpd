{
  "name": "gaia-profile-design",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-themes": "tsx ./app/scripts/generate-themes.ts",
    "generate-selectors": "tsx ./app/scripts/extract-css.ts",
    "predev": "npm run generate-themes && npm run generate-selectors",
    "prebuild": "npm run generate-themes && npm run generate-selectors",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "npm run generate-themes && npm run generate-selectors && react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/view": "^6.43.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@uiw/codemirror-themes": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5",
    "lenis": "^1.3.23",
    "lodash": "^4.18.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "toml": "^4.1.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vite": "^8"
  }
}
